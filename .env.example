SECRET_KEY=your-django-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# API rugby-live-data (RapidAPI)
RAPIDAPI_KEY=your-rapidapi-key

# api-sports.io (backup/alternative)
APISPORTS_KEY=your-apisports-key

# Sync endpoint — doit correspondre au secret GitHub Actions SYNC_SECRET_TOKEN
SYNC_SECRET_TOKEN=your-sync-secret-token

# Base de données (laisser vide pour SQLite en dev)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Email (en dev, utiliser le backend console dans settings.py)
# EMAIL_HOST=smtp.ionos.fr
# EMAIL_PORT=587
# EMAIL_HOST_USER=noreply@ovalpronos.com
# EMAIL_HOST_PASSWORD=your-email-password
