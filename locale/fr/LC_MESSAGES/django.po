#: templates/matches/rules.html:54
msgid ""
"Odds are based on Unibet odds (multiplied by 10 to avoid decimals). A match "
"with high odds on the winner scores more points, but you take more risk."
msgstr ""
"Les cotes sont basées sur les cotes Unibet (multipliées par 10 pour éviter "
"les décimales). Un match avec une forte cote sur le vainqueur rapporte plus "
"de points, mais tu prends plus de risque."

#: templates/matches/rules.html:58
msgid "Example"
msgstr "Exemple"

#: templates/matches/rules.html:60
msgid ""
"Clermont — Perpignan, Perpignan odds: 63 (= 6.3 at Unibet), good gap "
"threshold: 3 pts"
msgstr ""
"Clermont — Perpignan, cote Perpignan : 63 (= 6,3 chez Unibet), seuil bon "
"écart : 3 pts"

